{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "boston-scientific-iknow-v2",
  "main": ".open-next/worker.js",
  "compatibility_date": "2026-04-18",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  }
}
